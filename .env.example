# Local development env. Copy to .env.local and fill in.
#
# In CI the Pages workflow reads VITE_WAITLIST_URL and VITE_SUPABASE_ANON_KEY
# from GitHub Variables (not Secrets — they're embedded in the public bundle
# and are not sensitive). VITE_SUPABASE_URL is derived from the existing
# SUPABASE_PROJECT_REF secret, so no separate variable is needed.

# Supabase function URL for the waitlist signup.
VITE_WAITLIST_URL=

# Supabase project URL and anon key, used by the client-side analytics helper
# to POST anonymous usage events to public.tool_events.
# Locally: set both. In CI: only the anon key is set as a Variable; the URL is
# derived from the project ref by the workflow.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
